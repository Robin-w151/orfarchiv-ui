{
  "name": "ui",
  "version": "4.16.0-next.1",
  "license": "MIT",
  "scripts": {
    "dev": "vite dev --host",
    "build": "vite build",
    "generate:csp-script-hashes": "node scripts/generate-csp-script-hashes.js",
    "preview": "vite build && vite --host 0.0.0.0 preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write --plugin-search-dir=. .",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "storybook": "storybook dev -p 6006 --no-open",
    "storybook:build": "storybook build",
    "prepare": "husky && npx svelte-kit sync"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.3",
    "@commitlint/config-conventional": "20.5.3",
    "@eslint/js": "10.0.1",
    "@mozilla/readability": "0.5.0",
    "@panzoom/panzoom": "4.6.2",
    "@playwright/test": "1.60.0",
    "@semantic-release/git": "10.0.1",
    "@skeletonlabs/floating-ui-svelte": "0.3.9",
    "@steeze-ui/heroicons": "2.4.2",
    "@steeze-ui/svelte-icon": "1.6.2",
    "@storybook/addon-docs": "10.4.0",
    "@storybook/addon-links": "10.4.0",
    "@storybook/builder-vite": "10.4.0",
    "@storybook/sveltekit": "10.4.0",
    "@sveltejs/adapter-node": "5.5.4",
    "@sveltejs/adapter-vercel": "6.3.3",
    "@sveltejs/kit": "2.60.1",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@tailwindcss/forms": "0.5.11",
    "@tailwindcss/vite": "4.3.0",
    "@trpc/client": "11.17.0",
    "@trpc/server": "11.17.0",
    "@types/dotenv-flow": "3.3.3",
    "@types/jsdom": "28.0.3",
    "@types/lodash.debounce": "4.0.9",
    "@types/luxon": "3.7.1",
    "@types/node": "24.12.4",
    "@vercel/analytics": "2.0.1",
    "@vercel/speed-insights": "2.0.0",
    "@vite-pwa/sveltekit": "1.1.0",
    "@vitest/coverage-v8": "4.1.6",
    "@vueless/storybook-dark-mode": "10.0.8",
    "acorn": "8.16.0",
    "browserlist": "1.0.2",
    "clsx": "2.1.1",
    "dexie": "4.4.2",
    "dompurify": "3.4.3",
    "dotenv-flow": "4.1.0",
    "easy-speech": "2.4.0",
    "effect": "3.21.2",
    "escodegen": "2.1.0",
    "eslint": "10.4.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-compat": "7.0.2",
    "eslint-plugin-storybook": "10.4.0",
    "eslint-plugin-svelte": "3.17.1",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "16.4.0",
    "lru-cache": "11.3.6",
    "luxon": "3.7.2",
    "mongodb": "7.2.0",
    "openai": "6.38.0",
    "prettier": "3.8.3",
