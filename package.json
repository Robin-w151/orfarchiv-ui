    "svelte-persisted-store": "0.12.0",
    "svelte-portal": "2.2.1",
    "tailwindcss": "4.3.0",
    "tslib": "2.8.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.3",
    "vite": "8.0.13",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "4.1.6",
    "winston": "3.19.0",
    "workbox-core": "7.4.1",
    "workbox-expiration": "7.4.1",
    "workbox-precaching": "7.4.1",
    "workbox-routing": "7.4.1",
    "workbox-strategies": "7.4.1",
    "zod": "4.4.3"
  },
  "overrides": {
